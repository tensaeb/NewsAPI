# --- Aiven PostgreSQL (recommended) ---
# 1. Copy "Service URI" from Aiven → use as DATABASE_URL (postgres:// or postgresql:// both work)
# 2. Download "CA certificate" from Aiven → save to certs/aiven-ca.pem
# 3. Set DATABASE_SSL_CA_PATH below
DATABASE_URL="postgresql://avnadmin:YOUR_PASSWORD@pg-XXXX.e.aivencloud.com:21068/defaultdb?sslmode=require"
DATABASE_SSL_CA_PATH="./certs/aiven-ca.pem"

# --- Local PostgreSQL ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/newsapi?schema=public"

# Optional: override SSL verification (dev only if you skip the CA file)
# DATABASE_SSL_REJECT_UNAUTHORIZED=false

JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="24h"
PORT=3000
NODE_ENV=development
READ_DEDUP_SECONDS=60
