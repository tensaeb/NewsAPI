{
  "name": "news-api",
  "version": "1.0.0",
  "private": true,
  "description": "Afrolink News API — authors publish, readers consume, analytics aggregate",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "postinstall": "prisma generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.vitest.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "argon2": "^0.44.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pg-boss": "^12.18.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.8.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.1",
    "typescript": "~5.7.3",
    "vitest": "^4.1.6"
  }
}
